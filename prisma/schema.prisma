model AttendancePolicy {
  id                        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                  String                   @map("school_id") @db.Uuid
  academicYearId            String                   @map("academic_year_id") @db.Uuid
  termId                    String                   @map("term_id") @db.Uuid
  scopeType                 AttendanceScopeType      @map("scope_type")
  scopeKey                  String                   @map("scope_key")
  stageId                   String?                  @map("stage_id") @db.Uuid
  gradeId                   String?                  @map("grade_id") @db.Uuid
  sectionId                 String?                  @map("section_id") @db.Uuid
  classroomId               String?                  @map("classroom_id") @db.Uuid
  nameAr                    String                   @map("name_ar")
  nameEn                    String                   @map("name_en")
  descriptionAr             String?                  @map("description_ar")
  descriptionEn             String?                  @map("description_en")
  notes                     String?
  mode                      AttendanceMode
  dailyComputationStrategy  DailyComputationStrategy @default(MANUAL) @map("daily_computation_strategy")
  requireExcuseAttachment   Boolean                  @default(false) @map("require_excuse_attachment")
