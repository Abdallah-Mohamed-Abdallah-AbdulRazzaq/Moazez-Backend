  expiresAt       DateTime?                             @map("expires_at")
  metadata        Json?
  createdAt       DateTime                              @default(now()) @map("created_at")
  updatedAt       DateTime                              @updatedAt @map("updated_at")

  school        School                              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  recipientUser User                                @relation("CommunicationNotificationsRecipientUser", fields: [recipientUserId], references: [id], onDelete: Restrict)
  actorUser     User?                               @relation("CommunicationNotificationsActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  template      NotificationTemplate?               @relation("CommunicationNotificationsTemplate", fields: [templateId, schoolId], references: [id, schoolId], onDelete: Restrict)
  deliveries    CommunicationNotificationDelivery[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([recipientUserId])
  @@index([actorUserId])
  @@index([templateId])
  @@index([schoolId, recipientUserId])
  @@index([schoolId, recipientUserId, status])
  @@index([schoolId, createdAt(sort: Desc)])
  @@index([schoolId, sourceModule, sourceType, sourceId])
  @@index([status])
  @@index([type])
  @@index([expiresAt])
  @@map("communication_notifications")
}

model CommunicationNotificationDelivery {
  id                String                                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId          String                                   @map("school_id") @db.Uuid
  notificationId    String                                   @map("notification_id") @db.Uuid
  channel           CommunicationNotificationDeliveryChannel
  status            CommunicationNotificationDeliveryStatus  @default(PENDING)
  provider          String?
  providerMessageId String?                                  @map("provider_message_id")
  errorCode         String?                                  @map("error_code")
  errorMessage      String?                                  @map("error_message")
  attemptedAt       DateTime?                                @map("attempted_at")
  sentAt            DateTime?                                @map("sent_at")
  deliveredAt       DateTime?                                @map("delivered_at")
  failedAt          DateTime?                                @map("failed_at")
  metadata          Json?
  createdAt         DateTime                                 @default(now()) @map("created_at")
  updatedAt         DateTime                                 @updatedAt @map("updated_at")

  school       School                    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  notification CommunicationNotification @relation(fields: [notificationId, schoolId], references: [id, schoolId], onDelete: Restrict)

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([notificationId])
  @@index([schoolId, channel, status])
  @@index([channel])
  @@index([status])
  @@index([providerMessageId])
  @@map("communication_notification_deliveries")
}

// ============================================================
// AUDIT - append-only activity trail
// ============================================================

model AuditLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId        String?      @map("actor_id") @db.Uuid
  userType       UserType?    @map("user_type")
  organizationId String?      @map("organization_id") @db.Uuid
  schoolId       String?      @map("school_id") @db.Uuid
  module         String
  action         String
  resourceType   String       @map("resource_type")
  resourceId     String?      @map("resource_id")
  before         Json?
  after          Json?
  outcome        AuditOutcome
  ipAddress      String?      @map("ip_address")
  userAgent      String?      @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  actor        User?         @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  school       School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([module, action])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ============================================================
// FILES — object storage metadata (bytes live in S3/MinIO)
// ============================================================

model File {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?        @map("organization_id") @db.Uuid
  schoolId       String?        @map("school_id") @db.Uuid
  uploaderId     String?        @map("uploader_id") @db.Uuid
  bucket         String
  objectKey      String         @map("object_key")
  originalName   String         @map("original_name")
  mimeType       String         @map("mime_type")
  sizeBytes      BigInt         @map("size_bytes")
  checksumSha256 String?        @map("checksum_sha256")
  visibility     FileVisibility @default(PRIVATE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization                         Organization?                         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  school                               School?                               @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  uploader                             User?                                 @relation("FileUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  attachments                          Attachment[]
  reinforcementProofSubmissions        ReinforcementSubmission[]             @relation("ReinforcementSubmissionProofFile")
  applicationDocuments                 ApplicationDocument[]
  studentDocuments                     StudentDocument[]
  importJobsUploaded                   ImportJob[]                           @relation("ImportJobUploadedFile")
  heroBadges                           HeroBadge[]
  rewardCatalogItemImages              RewardCatalogItem[]                   @relation("RewardCatalogItemImageFile")
  communicationConversationAvatars     CommunicationConversation[]           @relation("CommunicationConversationAvatarFile")
  communicationMessageAttachments      CommunicationMessageAttachment[]
  communicationAnnouncementImages      CommunicationAnnouncement[]           @relation("CommunicationAnnouncementImageFile")
  communicationAnnouncementAttachments CommunicationAnnouncementAttachment[]

  @@unique([bucket, objectKey])
  @@index([organizationId])
  @@index([schoolId])
  @@index([uploaderId])
  @@index([visibility])
  @@index([deletedAt])
  @@map("files")
}

model Attachment {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId       String  @map("file_id") @db.Uuid
  schoolId     String  @map("school_id") @db.Uuid
  resourceType String  @map("resource_type")
  resourceId   String  @map("resource_id")
  createdById  String? @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  file      File   @relation(fields: [fileId], references: [id], onDelete: Restrict)
  school    School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  createdBy User?  @relation("AttachmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([fileId, resourceType, resourceId])
  @@index([fileId])
  @@index([schoolId])
  @@index([schoolId, resourceType, resourceId])
  @@index([createdById])
  @@map("attachments")
}

model ImportJob {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String          @map("school_id") @db.Uuid
  uploadedFileId String          @map("uploaded_file_id") @db.Uuid
  type           String
  status         ImportJobStatus @default(PENDING)
  reportJson     Json?           @map("report_json")
  createdById    String?         @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school       School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  uploadedFile File   @relation("ImportJobUploadedFile", fields: [uploadedFileId], references: [id], onDelete: Restrict)
  createdBy    User?  @relation("ImportJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, status, createdAt(sort: Desc)])
  @@index([schoolId, type])
  @@index([uploadedFileId])
  @@index([createdById])
  @@map("import_jobs")
}
