model GradeAssessment {
  id                  String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId            String                        @map("school_id") @db.Uuid
  academicYearId      String                        @map("academic_year_id") @db.Uuid
  termId              String                        @map("term_id") @db.Uuid
  subjectId           String                        @map("subject_id") @db.Uuid
  scopeType           GradeScopeType                @map("scope_type")
  scopeKey            String                        @map("scope_key") @db.Uuid
  stageId             String?                       @map("stage_id") @db.Uuid
  gradeId             String?                       @map("grade_id") @db.Uuid
  sectionId           String?                       @map("section_id") @db.Uuid
  classroomId         String?                       @map("classroom_id") @db.Uuid
  titleEn             String?                       @map("title_en")
  titleAr             String?                       @map("title_ar")
  type                GradeAssessmentType
  deliveryMode        GradeAssessmentDeliveryMode   @default(SCORE_ONLY) @map("delivery_mode")
  date                DateTime                      @db.Date
  weight              Decimal                       @db.Decimal(5, 2)
  maxScore            Decimal                       @map("max_score") @db.Decimal(7, 2)
  expectedTimeMinutes Int?                          @map("expected_time_minutes")
  approvalStatus      GradeAssessmentApprovalStatus @default(DRAFT) @map("approval_status")
  publishedAt         DateTime?                     @map("published_at")
  publishedById       String?                       @map("published_by_id") @db.Uuid
  approvedAt          DateTime?                     @map("approved_at")
  approvedById        String?                       @map("approved_by_id") @db.Uuid
  lockedAt            DateTime?                     @map("locked_at")
  lockedById          String?                       @map("locked_by_id") @db.Uuid
  createdById         String?                       @map("created_by_id") @db.Uuid
  createdAt           DateTime                      @default(now()) @map("created_at")
  updatedAt           DateTime                      @updatedAt @map("updated_at")
  deletedAt           DateTime?                     @map("deleted_at")

  school            School                          @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear      AcademicYear                    @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term              Term                            @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  subject           Subject                         @relation(fields: [subjectId, schoolId], references: [id, schoolId], onDelete: Restrict)
  stage             Stage?                          @relation(fields: [stageId, schoolId], references: [id, schoolId], onDelete: Restrict)
  grade             Grade?                          @relation(fields: [gradeId, schoolId], references: [id, schoolId], onDelete: Restrict)
  section           Section?                        @relation(fields: [sectionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom         Classroom?                      @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  publishedBy       User?                           @relation("GradeAssessmentPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  approvedBy        User?                           @relation("GradeAssessmentApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  lockedBy          User?                           @relation("GradeAssessmentLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  createdBy         User?                           @relation("GradeAssessmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  questions         GradeAssessmentQuestion[]
  questionOptions   GradeAssessmentQuestionOption[]
  submissions       GradeSubmission[]
  submissionAnswers GradeSubmissionAnswer[]
  items             GradeItem[]

  @@unique([id, schoolId], map: "grade_assessments_id_school_id_unique")
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([subjectId])
  @@index([stageId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([classroomId])
  @@index([publishedById])
  @@index([approvedById])
  @@index([lockedById])
  @@index([createdById])
  @@index([scopeType, scopeKey])
  @@index([schoolId, academicYearId, termId])
  @@index([schoolId, termId, subjectId])
  @@index([schoolId, termId, scopeType, scopeKey])
  @@index([schoolId, termId, approvalStatus])
  @@index([schoolId, deletedAt])
  @@map("grade_assessments")
}

model GradeItem {
