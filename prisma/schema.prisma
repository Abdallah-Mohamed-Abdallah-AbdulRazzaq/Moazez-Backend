// ============================================================
// STUDENTS - source-of-truth learner records and placements
// ============================================================

model Student {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String        @map("school_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  applicationId  String?       @map("application_id") @db.Uuid
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  birthDate      DateTime?     @map("birth_date") @db.Date
  status         StudentStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school         School                 @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  application    Application?           @relation(fields: [applicationId, schoolId], references: [id, schoolId], onDelete: Restrict)
  guardians      StudentGuardian[]
  enrollments    Enrollment[]
  documents      StudentDocument[]
  medicalProfile StudentMedicalProfile?
  notes          StudentNote[]

  @@unique([id, schoolId])
  @@unique([applicationId, schoolId])
  @@index([schoolId])
  @@index([organizationId])
  @@index([applicationId])
  @@index([schoolId, status, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("students")
}

model Guardian {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String  @map("school_id") @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  userId         String? @map("user_id") @db.Uuid
  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  phone          String
  email          String?
  relation       String
  isPrimary      Boolean @default(false) @map("is_primary")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school       School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User?             @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)
  students     StudentGuardian[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([organizationId])
  @@index([userId])
  @@index([schoolId, relation])
  @@index([deletedAt])
  @@map("guardians")
}

model StudentGuardian {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String  @map("school_id") @db.Uuid
  studentId  String  @map("student_id") @db.Uuid
  guardianId String  @map("guardian_id") @db.Uuid
  isPrimary  Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student  Student  @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  guardian Guardian @relation(fields: [guardianId, schoolId], references: [id, schoolId], onDelete: Restrict)

  @@unique([schoolId, studentId, guardianId])
  @@index([schoolId])
  @@index([studentId])
  @@index([guardianId])
  @@index([schoolId, studentId, isPrimary])
  @@map("student_guardian_links")
}

model Enrollment {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String                  @map("school_id") @db.Uuid
  studentId      String                  @map("student_id") @db.Uuid
  academicYearId String                  @map("academic_year_id") @db.Uuid
  termId         String?                 @map("term_id") @db.Uuid
  classroomId    String                  @map("classroom_id") @db.Uuid
  status         StudentEnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime                @map("enrolled_at")
  endedAt        DateTime?               @map("ended_at")
  exitReason     String?                 @map("exit_reason")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term         Term?        @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom    Classroom    @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([termId])
  @@index([classroomId])
  @@index([schoolId, studentId, status])
  @@index([schoolId, academicYearId, termId, status])
  @@index([deletedAt])
  @@map("student_enrollments")
}

model StudentDocument {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String                @map("school_id") @db.Uuid
  studentId    String                @map("student_id") @db.Uuid
  fileId       String                @map("file_id") @db.Uuid
  documentType String                @map("document_type")
  status       StudentDocumentStatus @default(MISSING)
  notes        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@index([schoolId])
  @@index([studentId])
  @@index([fileId])
  @@index([schoolId, status])
  @@index([schoolId, studentId, documentType])
  @@map("student_documents")
}

model StudentMedicalProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  studentId      String   @map("student_id") @db.Uuid
  bloodType      String?  @map("blood_type")
  allergies      String?
  conditions     String[] @default([])
  medications    String[] @default([])
  emergencyNotes String?  @map("emergency_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)

  @@unique([studentId, schoolId])
  @@index([schoolId])
  @@index([studentId])
  @@map("student_medical_profiles")
}

model StudentNote {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String               @map("school_id") @db.Uuid
  studentId    String               @map("student_id") @db.Uuid
  note         String
  category     StudentNoteCategory?
  authorUserId String               @map("author_user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school     School  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student    Student @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  authorUser User    @relation("StudentNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([schoolId])
  @@index([studentId])
  @@index([authorUserId])
  @@index([schoolId, studentId, createdAt(sort: Desc)])
  @@map("student_notes")
}

// ============================================================
// AUDIT - append-only activity trail
// ============================================================

model AuditLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId        String?      @map("actor_id") @db.Uuid
  userType       UserType?    @map("user_type")
  organizationId String?      @map("organization_id") @db.Uuid
  schoolId       String?      @map("school_id") @db.Uuid
  module         String
  action         String
  resourceType   String       @map("resource_type")
  resourceId     String?      @map("resource_id")
  before         Json?
  after          Json?
  outcome        AuditOutcome
  ipAddress      String?      @map("ip_address")
  userAgent      String?      @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  actor        User?         @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  school       School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([module, action])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ============================================================
// FILES — object storage metadata (bytes live in S3/MinIO)
// ============================================================

model File {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?        @map("organization_id") @db.Uuid
  schoolId       String?        @map("school_id") @db.Uuid
  uploaderId     String?        @map("uploader_id") @db.Uuid
  bucket         String
  objectKey      String         @map("object_key")
  originalName   String         @map("original_name")
  mimeType       String         @map("mime_type")
  sizeBytes      BigInt         @map("size_bytes")
  checksumSha256 String?        @map("checksum_sha256")
  visibility     FileVisibility @default(PRIVATE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization         Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  school               School?               @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  uploader             User?                 @relation("FileUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  attachments          Attachment[]
  applicationDocuments ApplicationDocument[]
  studentDocuments     StudentDocument[]
  importJobsUploaded   ImportJob[]           @relation("ImportJobUploadedFile")

  @@unique([bucket, objectKey])
  @@index([organizationId])
  @@index([schoolId])
  @@index([uploaderId])
  @@index([visibility])
  @@index([deletedAt])
  @@map("files")
}

model Attachment {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId       String  @map("file_id") @db.Uuid
  schoolId     String  @map("school_id") @db.Uuid
  resourceType String  @map("resource_type")
  resourceId   String  @map("resource_id")
  createdById  String? @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  file      File   @relation(fields: [fileId], references: [id], onDelete: Restrict)
  school    School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  createdBy User?  @relation("AttachmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([fileId, resourceType, resourceId])
  @@index([fileId])
  @@index([schoolId])
  @@index([schoolId, resourceType, resourceId])
  @@index([createdById])
  @@map("attachments")
}

model ImportJob {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String          @map("school_id") @db.Uuid
  uploadedFileId String          @map("uploaded_file_id") @db.Uuid
  type           String
  status         ImportJobStatus @default(PENDING)
  reportJson     Json?           @map("report_json")
  createdById    String?         @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school       School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  uploadedFile File   @relation("ImportJobUploadedFile", fields: [uploadedFileId], references: [id], onDelete: Restrict)
  createdBy    User?  @relation("ImportJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, status, createdAt(sort: Desc)])
  @@index([schoolId, type])
  @@index([uploadedFileId])
  @@index([createdById])
  @@map("import_jobs")
}
