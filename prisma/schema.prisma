model Organization {
  id     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name   String
  slug   String             @unique
  status OrganizationStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  schools      School[]
  memberships  Membership[]
  auditLogs    AuditLog[]
  files        File[]
  leads        Lead[]
  applications Application[]
  students     Student[]
  guardians    Guardian[]

  @@index([status])
  @@index([deletedAt])
  @@map("organizations")
}

model School {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  slug           String
  status         SchoolStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  memberships                           Membership[]
  roles                                 Role[]
  schoolProfile                         SchoolProfile?
  securitySetting                       SecuritySetting?
  notificationTemplates                 NotificationTemplate[]
  notificationTemplateChannelStates     NotificationTemplateChannelState[]
  integrationConnections                IntegrationConnection[]
  backupJobs                            BackupJob[]
  academicYears                         AcademicYear[]
  terms                                 Term[]
  stages                                Stage[]
  grades                                Grade[]
  sections                              Section[]
  classrooms                            Classroom[]
  subjects                              Subject[]
  teacherSubjectAllocations             TeacherSubjectAllocation[]
  rooms                                 Room[]
  attachments                           Attachment[]
  importJobs                            ImportJob[]
  auditLogs                             AuditLog[]
  files                                 File[]
  leads                                 Lead[]
  applications                          Application[]
  applicationDocuments                  ApplicationDocument[]
  placementTests                        PlacementTest[]
  interviews                            Interview[]
  admissionDecisions                    AdmissionDecision[]
  students                              Student[]
  guardians                             Guardian[]
  studentGuardians                      StudentGuardian[]
  enrollments                           Enrollment[]
  studentDocuments                      StudentDocument[]
  studentMedicalProfiles                StudentMedicalProfile[]
  studentNotes                          StudentNote[]
  attendancePolicies                    AttendancePolicy[]
  attendanceSessions                    AttendanceSession[]
  attendanceEntries                     AttendanceEntry[]
  attendanceExcuseRequests              AttendanceExcuseRequest[]
  attendanceExcuseRequestSessions       AttendanceExcuseRequestSession[]
  gradeAssessments                      GradeAssessment[]
  gradeAssessmentQuestions              GradeAssessmentQuestion[]
  gradeAssessmentQuestionOptions        GradeAssessmentQuestionOption[]
  gradeSubmissions                      GradeSubmission[]
  gradeSubmissionAnswers                GradeSubmissionAnswer[]
  gradeSubmissionAnswerOptions          GradeSubmissionAnswerOption[]
  gradeItems                            GradeItem[]
  gradeRules                            GradeRule[]
  reinforcementTasks                    ReinforcementTask[]
  reinforcementTaskTargets              ReinforcementTaskTarget[]
  reinforcementTaskStages               ReinforcementTaskStage[]
  reinforcementAssignments              ReinforcementAssignment[]
  reinforcementSubmissions              ReinforcementSubmission[]
  reinforcementReviews                  ReinforcementReview[]
  reinforcementTaskTemplates            ReinforcementTaskTemplate[]
  reinforcementTaskTemplateStages       ReinforcementTaskTemplateStage[]
  xpPolicies                            XpPolicy[]
  xpLedgers                             XpLedger[]
  heroBadges                            HeroBadge[]
  heroMissions                          HeroMission[]
  heroMissionObjectives                 HeroMissionObjective[]
  heroMissionProgress                   HeroMissionProgress[]
  heroMissionObjectiveProgress          HeroMissionObjectiveProgress[]
  heroStudentBadges                     HeroStudentBadge[]
  heroJourneyEvents                     HeroJourneyEvent[]
  rewardCatalogItems                    RewardCatalogItem[]
  rewardRedemptions                     RewardRedemption[]
  behaviorCategories                    BehaviorCategory[]
  behaviorRecords                       BehaviorRecord[]
  behaviorPointLedgerEntries            BehaviorPointLedger[]
  communicationPolicy                   CommunicationPolicy?
  communicationConversations            CommunicationConversation[]
  communicationConversationParticipants CommunicationConversationParticipant[]
  communicationConversationInvites      CommunicationConversationInvite[]
  communicationConversationJoinRequests CommunicationConversationJoinRequest[]
  communicationMessages                 CommunicationMessage[]
  communicationMessageReads             CommunicationMessageRead[]
  communicationMessageDeliveries        CommunicationMessageDelivery[]
  communicationMessageReactions         CommunicationMessageReaction[]
  communicationMessageAttachments       CommunicationMessageAttachment[]
  communicationMessageReports           CommunicationMessageReport[]
  communicationModerationActions        CommunicationModerationAction[]
  communicationUserBlocks               CommunicationUserBlock[]
  communicationUserRestrictions         CommunicationUserRestriction[]
  communicationAnnouncements            CommunicationAnnouncement[]
  communicationAnnouncementAudiences    CommunicationAnnouncementAudience[]
  communicationAnnouncementReads        CommunicationAnnouncementRead[]
  communicationAnnouncementAttachments  CommunicationAnnouncementAttachment[]
  communicationNotifications            CommunicationNotification[]
  communicationNotificationDeliveries   CommunicationNotificationDelivery[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([deletedAt])
  @@map("schools")
}

