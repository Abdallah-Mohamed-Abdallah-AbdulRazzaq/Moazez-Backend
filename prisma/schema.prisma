model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique
  phone        String?    @unique
  passwordHash String?    @map("password_hash")
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  userType     UserType   @map("user_type")
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships                                    Membership[]
  sessions                                       Session[]
  auditLogsActing                                AuditLog[]                             @relation("AuditLogActor")
  filesUploaded                                  File[]                                 @relation("FileUploader")
  schoolProfilesUpdated                          SchoolProfile[]                        @relation("SchoolProfileUpdatedBy")
  securitySettingsUpdated                        SecuritySetting[]                      @relation("SecuritySettingUpdatedBy")
  backupJobsCreated                              BackupJob[]                            @relation("BackupJobCreatedBy")
  attachmentsCreated                             Attachment[]                           @relation("AttachmentCreatedBy")
  importJobsCreated                              ImportJob[]                            @relation("ImportJobCreatedBy")
  ownedLeads                                     Lead[]                                 @relation("LeadOwner")
  admissionInterviews                            Interview[]                            @relation("AdmissionInterviewInterviewer")
  admissionDecisionsCreated                      AdmissionDecision[]                    @relation("AdmissionDecisionDecidedBy")
  teacherSubjectAllocations                      TeacherSubjectAllocation[]             @relation("TeacherSubjectAllocationTeacher")
  guardianProfiles                               Guardian[]                             @relation("GuardianUser")
  studentNotesAuthored                           StudentNote[]                          @relation("StudentNoteAuthor")
  attendanceSessionsSubmitted                    AttendanceSession[]                    @relation("AttendanceSessionSubmittedBy")
  attendanceEntriesMarked                        AttendanceEntry[]                      @relation("AttendanceEntryMarkedBy")
  attendanceExcuseRequestsCreated                AttendanceExcuseRequest[]              @relation("AttendanceExcuseRequestCreatedBy")
  attendanceExcuseRequestsDecided                AttendanceExcuseRequest[]              @relation("AttendanceExcuseRequestDecidedBy")
  gradeAssessmentsPublished                      GradeAssessment[]                      @relation("GradeAssessmentPublishedBy")
  gradeAssessmentsApproved                       GradeAssessment[]                      @relation("GradeAssessmentApprovedBy")
  gradeAssessmentsLocked                         GradeAssessment[]                      @relation("GradeAssessmentLockedBy")
  gradeAssessmentsCreated                        GradeAssessment[]                      @relation("GradeAssessmentCreatedBy")
  gradeItemsEntered                              GradeItem[]                            @relation("GradeItemEnteredBy")
  gradeSubmissionsReviewed                       GradeSubmission[]                      @relation("GradeSubmissionReviewedBy")
  gradeSubmissionAnswersReviewed                 GradeSubmissionAnswer[]                @relation("GradeSubmissionAnswerReviewedBy")
  reinforcementTasksAssigned                     ReinforcementTask[]                    @relation("ReinforcementTaskAssignedBy")
  reinforcementTasksCreated                      ReinforcementTask[]                    @relation("ReinforcementTaskCreatedBy")
  reinforcementTasksCancelled                    ReinforcementTask[]                    @relation("ReinforcementTaskCancelledBy")
  reinforcementTemplatesCreated                  ReinforcementTaskTemplate[]            @relation("ReinforcementTemplateCreatedBy")
  reinforcementSubmissions                       ReinforcementSubmission[]              @relation("ReinforcementSubmissionSubmittedBy")
  reinforcementReviews                           ReinforcementReview[]                  @relation("ReinforcementReviewReviewedBy")
  xpLedgersActed                                 XpLedger[]                             @relation("XpLedgerActor")
  heroMissionsPublished                          HeroMission[]                          @relation("HeroMissionPublishedBy")
  heroMissionsArchived                           HeroMission[]                          @relation("HeroMissionArchivedBy")
  heroMissionsCreated                            HeroMission[]                          @relation("HeroMissionCreatedBy")
  heroObjectiveProgressCompleted                 HeroMissionObjectiveProgress[]         @relation("HeroObjectiveProgressCompletedBy")
  heroJourneyEventsActed                         HeroJourneyEvent[]                     @relation("HeroJourneyEventActor")
  rewardCatalogItemsCreated                      RewardCatalogItem[]                    @relation("RewardCatalogItemsCreatedByUser")
  rewardCatalogItemsPublished                    RewardCatalogItem[]                    @relation("RewardCatalogItemsPublishedByUser")
  rewardCatalogItemsArchived                     RewardCatalogItem[]                    @relation("RewardCatalogItemsArchivedByUser")
  rewardRedemptionsRequested                     RewardRedemption[]                     @relation("RewardRedemptionsRequestedByUser")
  rewardRedemptionsReviewed                      RewardRedemption[]                     @relation("RewardRedemptionsReviewedByUser")
  rewardRedemptionsFulfilled                     RewardRedemption[]                     @relation("RewardRedemptionsFulfilledByUser")
  rewardRedemptionsCancelled                     RewardRedemption[]                     @relation("RewardRedemptionsCancelledByUser")
  behaviorCategoriesCreated                      BehaviorCategory[]                     @relation("BehaviorCategoriesCreatedByUser")
  behaviorRecordsCreated                         BehaviorRecord[]                       @relation("BehaviorRecordsCreatedByUser")
  behaviorRecordsSubmitted                       BehaviorRecord[]                       @relation("BehaviorRecordsSubmittedByUser")
  behaviorRecordsReviewed                        BehaviorRecord[]                       @relation("BehaviorRecordsReviewedByUser")
  behaviorRecordsCancelled                       BehaviorRecord[]                       @relation("BehaviorRecordsCancelledByUser")
  behaviorPointLedgerActed                       BehaviorPointLedger[]                  @relation("BehaviorPointLedgerActorUser")
  communicationPoliciesCreated                   CommunicationPolicy[]                  @relation("CommunicationPoliciesCreatedByUser")
  communicationPoliciesUpdated                   CommunicationPolicy[]                  @relation("CommunicationPoliciesUpdatedByUser")
  communicationConversationsCreated              CommunicationConversation[]            @relation("CommunicationConversationsCreatedByUser")
  communicationConversationsArchived             CommunicationConversation[]            @relation("CommunicationConversationsArchivedByUser")
  communicationConversationsClosed               CommunicationConversation[]            @relation("CommunicationConversationsClosedByUser")
  communicationConversationParticipants          CommunicationConversationParticipant[] @relation("CommunicationConversationParticipantsUser")
  communicationConversationParticipantsInvited   CommunicationConversationParticipant[] @relation("CommunicationConversationParticipantsInvitedByUser")
  communicationConversationParticipantsRemoved   CommunicationConversationParticipant[] @relation("CommunicationConversationParticipantsRemovedByUser")
  communicationConversationInvitesReceived       CommunicationConversationInvite[]      @relation("CommunicationConversationInvitesInvitedUser")
  communicationConversationInvitesSent           CommunicationConversationInvite[]      @relation("CommunicationConversationInvitesInvitedByUser")
  communicationConversationJoinRequestsRequested CommunicationConversationJoinRequest[] @relation("CommunicationConversationJoinRequestsRequestedByUser")
  communicationConversationJoinRequestsReviewed  CommunicationConversationJoinRequest[] @relation("CommunicationConversationJoinRequestsReviewedByUser")
  communicationMessagesSent                      CommunicationMessage[]                 @relation("CommunicationMessagesSentByUser")
  communicationMessagesHidden                    CommunicationMessage[]                 @relation("CommunicationMessagesHiddenByUser")
  communicationMessagesDeleted                   CommunicationMessage[]                 @relation("CommunicationMessagesDeletedByUser")
  communicationMessageReads                      CommunicationMessageRead[]             @relation("CommunicationMessageReadsUser")
  communicationMessageDeliveries                 CommunicationMessageDelivery[]         @relation("CommunicationMessageDeliveriesRecipientUser")
  communicationMessageReactions                  CommunicationMessageReaction[]         @relation("CommunicationMessageReactionsUser")
  communicationMessageAttachmentsUploaded        CommunicationMessageAttachment[]       @relation("CommunicationMessageAttachmentsUploadedByUser")
  communicationMessageReportsFiled               CommunicationMessageReport[]           @relation("CommunicationMessageReportsReporterUser")
  communicationMessageReportsReviewed            CommunicationMessageReport[]           @relation("CommunicationMessageReportsReviewedByUser")
  communicationModerationActionsActed            CommunicationModerationAction[]        @relation("CommunicationModerationActionsActorUser")
  communicationModerationActionsTargeted         CommunicationModerationAction[]        @relation("CommunicationModerationActionsTargetUser")
  communicationUserBlocksCreated                 CommunicationUserBlock[]               @relation("CommunicationUserBlocksBlockerUser")
  communicationUserBlocksReceived                CommunicationUserBlock[]               @relation("CommunicationUserBlocksBlockedUser")
  communicationUserRestrictionsTargeted          CommunicationUserRestriction[]         @relation("CommunicationUserRestrictionsTargetUser")
  communicationUserRestrictionsApplied           CommunicationUserRestriction[]         @relation("CommunicationUserRestrictionsRestrictedByUser")
  communicationUserRestrictionsLifted            CommunicationUserRestriction[]         @relation("CommunicationUserRestrictionsLiftedByUser")
  communicationAnnouncementsCreated              CommunicationAnnouncement[]            @relation("CommunicationAnnouncementsCreatedByUser")
  communicationAnnouncementsUpdated              CommunicationAnnouncement[]            @relation("CommunicationAnnouncementsUpdatedByUser")
  communicationAnnouncementsPublished            CommunicationAnnouncement[]            @relation("CommunicationAnnouncementsPublishedByUser")
  communicationAnnouncementsArchived             CommunicationAnnouncement[]            @relation("CommunicationAnnouncementsArchivedByUser")
  communicationAnnouncementAudiences             CommunicationAnnouncementAudience[]    @relation("CommunicationAnnouncementAudiencesUser")
  communicationAnnouncementReads                 CommunicationAnnouncementRead[]        @relation("CommunicationAnnouncementReadsUser")
  communicationAnnouncementAttachmentsCreated    CommunicationAnnouncementAttachment[]  @relation("CommunicationAnnouncementAttachmentsCreatedByUser")
