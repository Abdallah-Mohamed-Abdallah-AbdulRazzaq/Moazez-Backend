  term         Term                @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  stage        Stage?              @relation(fields: [stageId, schoolId], references: [id, schoolId], onDelete: Restrict)
  grade        Grade?              @relation(fields: [gradeId, schoolId], references: [id, schoolId], onDelete: Restrict)
  section      Section?            @relation(fields: [sectionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom    Classroom?          @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  sessions     AttendanceSession[]

  @@unique([id, schoolId])
  @@unique([schoolId, academicYearId, termId, scopeType, scopeKey, nameAr], map: "attendance_policies_scope_name_ar_key")
  @@unique([schoolId, academicYearId, termId, scopeType, scopeKey, nameEn], map: "attendance_policies_scope_name_en_key")
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([stageId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([classroomId])
  @@index([schoolId, academicYearId, termId])
  @@index([schoolId, termId, scopeType, scopeKey])
  @@index([schoolId, isActive, deletedAt])
  @@index([deletedAt])
  @@map("attendance_policies")
}

model AttendanceSession {
