// Moazez backend Prisma schema.
// Sections are ordered: generator, datasource, enums, then models grouped by module.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserType {
  PLATFORM_USER
  ORGANIZATION_USER
  SCHOOL_USER
  TEACHER
  PARENT
  STUDENT
  APPLICANT
  PICKUP_DELEGATE
  SERVICE_ACCOUNT

  @@map("user_type")
}

enum MembershipStatus {
  ACTIVE
  INACTIVE
  TRANSFERRED
  SUSPENDED

  @@map("membership_status")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED

  @@map("organization_status")
}

enum SchoolStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED

  @@map("school_status")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DISABLED

  @@map("user_status")
}

enum AuditOutcome {
  SUCCESS
  FAILURE

  @@map("audit_outcome")
}

enum FileVisibility {
  PRIVATE
  PUBLIC

  @@map("file_visibility")
}

enum NotificationTemplateStatus {
  ACTIVE
  DRAFT

  @@map("notification_template_status")
}

enum NotificationChannel {
  EMAIL
  SMS
  IN_APP

  @@map("notification_channel")
}

enum IntegrationConnectionStatus {
  CONNECTED
  DISCONNECTED
  NEEDS_ATTENTION

  @@map("integration_connection_status")
}

enum IntegrationFieldType {
  TEXT
  PASSWORD
  URL
  EMAIL
  SELECT

  @@map("integration_field_type")
}

enum BackupJobStatus {
  COMPLETED
  RUNNING
  FAILED

  @@map("backup_job_status")
}

enum BackupJobType {
