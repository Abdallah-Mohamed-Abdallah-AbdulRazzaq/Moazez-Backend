// ATTENDANCE - policies, sessions, entries, excuses
// ============================================================

model AttendancePolicy {
  id                        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                  String                   @map("school_id") @db.Uuid
  academicYearId            String                   @map("academic_year_id") @db.Uuid
  termId                    String                   @map("term_id") @db.Uuid
  scopeType                 AttendanceScopeType      @map("scope_type")
  scopeKey                  String                   @map("scope_key")
  stageId                   String?                  @map("stage_id") @db.Uuid
  gradeId                   String?                  @map("grade_id") @db.Uuid
  sectionId                 String?                  @map("section_id") @db.Uuid
  classroomId               String?                  @map("classroom_id") @db.Uuid
  nameAr                    String                   @map("name_ar")
  nameEn                    String                   @map("name_en")
  descriptionAr             String?                  @map("description_ar")
  descriptionEn             String?                  @map("description_en")
  notes                     String?
  mode                      AttendanceMode
  dailyComputationStrategy  DailyComputationStrategy @default(MANUAL) @map("daily_computation_strategy")
  requireExcuseAttachment   Boolean                  @default(false) @map("require_excuse_attachment")
  allowParentExcuseRequests Boolean                  @default(true) @map("allow_parent_excuse_requests")
  notifyGuardiansOnAbsence  Boolean                  @default(true) @map("notify_guardians_on_absence")
  effectiveFrom             DateTime?                @map("effective_from") @db.Date
  effectiveTo               DateTime?                @map("effective_to") @db.Date
  isActive                  Boolean                  @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school       School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear AcademicYear        @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term         Term                @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  stage        Stage?              @relation(fields: [stageId, schoolId], references: [id, schoolId], onDelete: Restrict)
  grade        Grade?              @relation(fields: [gradeId, schoolId], references: [id, schoolId], onDelete: Restrict)
  section      Section?            @relation(fields: [sectionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom    Classroom?          @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  sessions     AttendanceSession[]

  @@unique([id, schoolId])
  @@unique([schoolId, academicYearId, termId, scopeType, scopeKey, nameAr], map: "attendance_policies_scope_name_ar_key")
  @@unique([schoolId, academicYearId, termId, scopeType, scopeKey, nameEn], map: "attendance_policies_scope_name_en_key")
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([stageId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([classroomId])
  @@index([schoolId, academicYearId, termId])
  @@index([schoolId, termId, scopeType, scopeKey])
  @@index([schoolId, isActive, deletedAt])
  @@index([deletedAt])
  @@map("attendance_policies")
}

model AttendanceSession {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String                  @map("school_id") @db.Uuid
  academicYearId String                  @map("academic_year_id") @db.Uuid
  termId         String                  @map("term_id") @db.Uuid
  date           DateTime                @db.Date
  scopeType      AttendanceScopeType     @map("scope_type")
  scopeKey       String                  @map("scope_key")
  stageId        String?                 @map("stage_id") @db.Uuid
  gradeId        String?                 @map("grade_id") @db.Uuid
  sectionId      String?                 @map("section_id") @db.Uuid
  classroomId    String?                 @map("classroom_id") @db.Uuid
  mode           AttendanceMode
  periodId       String?                 @map("period_id")
  periodKey      String                  @map("period_key")
  periodLabelAr  String?                 @map("period_label_ar")
  periodLabelEn  String?                 @map("period_label_en")
  policyId       String?                 @map("policy_id") @db.Uuid
  status         AttendanceSessionStatus @default(DRAFT)
  submittedAt    DateTime?               @map("submitted_at")
  submittedById  String?                 @map("submitted_by_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school                      School                           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear                AcademicYear                     @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term                        Term                             @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  stage                       Stage?                           @relation(fields: [stageId, schoolId], references: [id, schoolId], onDelete: Restrict)
  grade                       Grade?                           @relation(fields: [gradeId, schoolId], references: [id, schoolId], onDelete: Restrict)
  section                     Section?                         @relation(fields: [sectionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom                   Classroom?                       @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  policy                      AttendancePolicy?                @relation(fields: [policyId, schoolId], references: [id, schoolId], onDelete: Restrict)
  submittedBy                 User?                            @relation("AttendanceSessionSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  entries                     AttendanceEntry[]
  linkedExcuseRequestSessions AttendanceExcuseRequestSession[]

  @@unique([id, schoolId])
  @@unique([schoolId, academicYearId, termId, date, scopeType, scopeKey, mode, periodKey])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([date])
  @@index([status])
  @@index([stageId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([classroomId])
  @@index([policyId])
  @@index([submittedById])
  @@index([schoolId, termId, date])
  @@index([schoolId, termId, status])
  @@index([schoolId, termId, scopeType, scopeKey])
  @@index([deletedAt])
  @@map("attendance_sessions")
}

model AttendanceEntry {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId          String           @map("school_id") @db.Uuid
  sessionId         String           @map("session_id") @db.Uuid
  studentId         String           @map("student_id") @db.Uuid
  enrollmentId      String?          @map("enrollment_id") @db.Uuid
  status            AttendanceStatus @default(UNMARKED)
  lateMinutes       Int?             @map("late_minutes")
  earlyLeaveMinutes Int?             @map("early_leave_minutes")
  excuseReason      String?          @map("excuse_reason")
  note              String?
  markedById        String?          @map("marked_by_id") @db.Uuid
  markedAt          DateTime?        @map("marked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school     School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  session    AttendanceSession @relation(fields: [sessionId, schoolId], references: [id, schoolId], onDelete: Cascade)
  student    Student           @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  enrollment Enrollment?       @relation(fields: [enrollmentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  markedBy   User?             @relation("AttendanceEntryMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)

  @@unique([id, schoolId])
  @@unique([schoolId, sessionId, studentId])
  @@index([schoolId])
  @@index([sessionId])
  @@index([studentId])
  @@index([enrollmentId])
  @@index([status])
  @@index([markedById])
  @@map("attendance_entries")
}

model AttendanceExcuseRequest {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId           String                 @map("school_id") @db.Uuid
  academicYearId     String                 @map("academic_year_id") @db.Uuid
  termId             String                 @map("term_id") @db.Uuid
  studentId          String                 @map("student_id") @db.Uuid
  type               AttendanceExcuseType
  status             AttendanceExcuseStatus @default(PENDING)
  dateFrom           DateTime               @map("date_from") @db.Date
  dateTo             DateTime               @map("date_to") @db.Date
  selectedPeriodKeys String[]               @default([]) @map("selected_period_keys")
  lateMinutes        Int?                   @map("late_minutes")
  earlyLeaveMinutes  Int?                   @map("early_leave_minutes")
  reasonAr           String?                @map("reason_ar")
  reasonEn           String?                @map("reason_en")
  decisionNote       String?                @map("decision_note")
  createdById        String?                @map("created_by_id") @db.Uuid
  decidedById        String?                @map("decided_by_id") @db.Uuid
  decidedAt          DateTime?              @map("decided_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school         School                           @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear                     @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term           Term                             @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  student        Student                          @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  createdBy      User?                            @relation("AttendanceExcuseRequestCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  decidedBy      User?                            @relation("AttendanceExcuseRequestDecidedBy", fields: [decidedById], references: [id], onDelete: SetNull)
  linkedSessions AttendanceExcuseRequestSession[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([studentId])
  @@index([status])
  @@index([dateFrom, dateTo])
  @@index([createdById])
  @@index([decidedById])
  @@index([deletedAt])
  @@index([schoolId, termId, status])
  @@index([schoolId, studentId, dateFrom, dateTo])
  @@map("attendance_excuse_requests")
}

model AttendanceExcuseRequestSession {
  schoolId                  String @map("school_id") @db.Uuid
  attendanceExcuseRequestId String @map("attendance_excuse_request_id") @db.Uuid
  attendanceSessionId       String @map("attendance_session_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  school                  School                  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  attendanceExcuseRequest AttendanceExcuseRequest @relation(fields: [attendanceExcuseRequestId, schoolId], references: [id, schoolId], onDelete: Cascade)
  attendanceSession       AttendanceSession       @relation(fields: [attendanceSessionId, schoolId], references: [id, schoolId], onDelete: Cascade)

  @@id([attendanceExcuseRequestId, attendanceSessionId])
  @@index([schoolId])
  @@index([attendanceSessionId])
  @@map("attendance_excuse_request_sessions")
}

// ============================================================
// AUDIT - append-only activity trail
// ============================================================

model AuditLog {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId        String?      @map("actor_id") @db.Uuid
  userType       UserType?    @map("user_type")
  organizationId String?      @map("organization_id") @db.Uuid
  schoolId       String?      @map("school_id") @db.Uuid
  module         String
  action         String
  resourceType   String       @map("resource_type")
  resourceId     String?      @map("resource_id")
  before         Json?
  after          Json?
  outcome        AuditOutcome
  ipAddress      String?      @map("ip_address")
  userAgent      String?      @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  actor        User?         @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  school       School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([module, action])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ============================================================
// FILES — object storage metadata (bytes live in S3/MinIO)
// ============================================================

model File {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?        @map("organization_id") @db.Uuid
  schoolId       String?        @map("school_id") @db.Uuid
  uploaderId     String?        @map("uploader_id") @db.Uuid
  bucket         String
  objectKey      String         @map("object_key")
  originalName   String         @map("original_name")
  mimeType       String         @map("mime_type")
  sizeBytes      BigInt         @map("size_bytes")
  checksumSha256 String?        @map("checksum_sha256")
  visibility     FileVisibility @default(PRIVATE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization         Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  school               School?               @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  uploader             User?                 @relation("FileUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  attachments          Attachment[]
  applicationDocuments ApplicationDocument[]
  studentDocuments     StudentDocument[]
  importJobsUploaded   ImportJob[]           @relation("ImportJobUploadedFile")

  @@unique([bucket, objectKey])
  @@index([organizationId])
  @@index([schoolId])
  @@index([uploaderId])
  @@index([visibility])
  @@index([deletedAt])
  @@map("files")
}

model Attachment {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileId       String  @map("file_id") @db.Uuid
  schoolId     String  @map("school_id") @db.Uuid
  resourceType String  @map("resource_type")
  resourceId   String  @map("resource_id")
  createdById  String? @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  file      File   @relation(fields: [fileId], references: [id], onDelete: Restrict)
  school    School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  createdBy User?  @relation("AttachmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([fileId, resourceType, resourceId])
  @@index([fileId])
  @@index([schoolId])
  @@index([schoolId, resourceType, resourceId])
  @@index([createdById])
  @@map("attachments")
}

model ImportJob {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String          @map("school_id") @db.Uuid
  uploadedFileId String          @map("uploaded_file_id") @db.Uuid
  type           String
  status         ImportJobStatus @default(PENDING)
  reportJson     Json?           @map("report_json")
  createdById    String?         @map("created_by_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school       School @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  uploadedFile File   @relation("ImportJobUploadedFile", fields: [uploadedFileId], references: [id], onDelete: Restrict)
  createdBy    User?  @relation("ImportJobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, status, createdAt(sort: Desc)])
  @@index([schoolId, type])
  @@index([uploadedFileId])
  @@index([createdById])
  @@map("import_jobs")
}
