// ============================================================
// STUDENTS - source-of-truth learner records and placements
// ============================================================

model Student {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String        @map("school_id") @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  applicationId  String?       @map("application_id") @db.Uuid
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  birthDate      DateTime?     @map("birth_date") @db.Date
  status         StudentStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school                   School                    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  organization             Organization              @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  application              Application?              @relation(fields: [applicationId, schoolId], references: [id, schoolId], onDelete: Restrict)
  guardians                StudentGuardian[]
  enrollments              Enrollment[]
  documents                StudentDocument[]
  medicalProfile           StudentMedicalProfile?
  notes                    StudentNote[]
  attendanceEntries        AttendanceEntry[]
  attendanceExcuseRequests AttendanceExcuseRequest[]
  gradeItems               GradeItem[]
  gradeSubmissions         GradeSubmission[]
  gradeSubmissionAnswers   GradeSubmissionAnswer[]
  reinforcementTaskTargets ReinforcementTaskTarget[]
  reinforcementAssignments ReinforcementAssignment[]
  reinforcementSubmissions ReinforcementSubmission[]
  reinforcementReviews     ReinforcementReview[]
  xpLedgers                XpLedger[]

  @@unique([id, schoolId])
  @@unique([applicationId, schoolId])
  @@index([schoolId])
  @@index([organizationId])
  @@index([applicationId])
  @@index([schoolId, status, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@map("students")
}

model Guardian {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String  @map("school_id") @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  userId         String? @map("user_id") @db.Uuid
  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  phone          String
  email          String?
  relation       String
  isPrimary      Boolean @default(false) @map("is_primary")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school       School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user         User?             @relation("GuardianUser", fields: [userId], references: [id], onDelete: SetNull)
  students     StudentGuardian[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([organizationId])
  @@index([userId])
  @@index([schoolId, relation])
  @@index([deletedAt])
  @@map("guardians")
}

model StudentGuardian {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String  @map("school_id") @db.Uuid
  studentId  String  @map("student_id") @db.Uuid
  guardianId String  @map("guardian_id") @db.Uuid
  isPrimary  Boolean @default(false) @map("is_primary")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school   School   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student  Student  @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  guardian Guardian @relation(fields: [guardianId, schoolId], references: [id, schoolId], onDelete: Restrict)

  @@unique([schoolId, studentId, guardianId])
  @@index([schoolId])
  @@index([studentId])
  @@index([guardianId])
  @@index([schoolId, studentId, isPrimary])
  @@map("student_guardian_links")
}

model Enrollment {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId       String                  @map("school_id") @db.Uuid
  studentId      String                  @map("student_id") @db.Uuid
  academicYearId String                  @map("academic_year_id") @db.Uuid
  termId         String?                 @map("term_id") @db.Uuid
  classroomId    String                  @map("classroom_id") @db.Uuid
  status         StudentEnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime                @map("enrolled_at")
  endedAt        DateTime?               @map("ended_at")
  exitReason     String?                 @map("exit_reason")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school                   School                    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student                  Student                   @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  academicYear             AcademicYear              @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term                     Term?                     @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom                Classroom                 @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  attendanceEntries        AttendanceEntry[]
  gradeItems               GradeItem[]
  gradeSubmissions         GradeSubmission[]
  reinforcementAssignments ReinforcementAssignment[]
  reinforcementSubmissions ReinforcementSubmission[]
  xpLedgers                XpLedger[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([termId])
  @@index([classroomId])
  @@index([schoolId, studentId, status])
  @@index([schoolId, academicYearId, termId, status])
  @@index([deletedAt])
  @@map("student_enrollments")
}

model StudentDocument {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String                @map("school_id") @db.Uuid
  studentId    String                @map("student_id") @db.Uuid
  fileId       String                @map("file_id") @db.Uuid
  documentType String                @map("document_type")
  status       StudentDocumentStatus @default(MISSING)
  notes        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  student Student @relation(fields: [studentId, schoolId], references: [id, schoolId], onDelete: Restrict)
  file    File    @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@index([schoolId])
  @@index([studentId])
  @@index([fileId])
  @@index([schoolId, status])
