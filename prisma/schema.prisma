  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([organizationId])
  @@index([ownerUserId])
  @@index([schoolId, status, createdAt(sort: Desc)])
  @@index([schoolId, channel, createdAt(sort: Desc)])
