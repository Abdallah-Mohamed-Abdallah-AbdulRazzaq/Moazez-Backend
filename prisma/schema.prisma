model ReinforcementTask {
  id                 String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId           String                   @map("school_id") @db.Uuid
  academicYearId     String                   @map("academic_year_id") @db.Uuid
  termId             String                   @map("term_id") @db.Uuid
  subjectId          String?                  @map("subject_id") @db.Uuid
  titleEn            String?                  @map("title_en")
  titleAr            String?                  @map("title_ar")
  descriptionEn      String?                  @map("description_en")
  descriptionAr      String?                  @map("description_ar")
  source             ReinforcementSource
  status             ReinforcementTaskStatus  @default(NOT_COMPLETED)
  rewardType         ReinforcementRewardType? @map("reward_type")
  rewardValue        Decimal?                 @map("reward_value") @db.Decimal(10, 2)
  rewardLabelEn      String?                  @map("reward_label_en")
  rewardLabelAr      String?                  @map("reward_label_ar")
  dueDate            DateTime?                @map("due_date")
  assignedById       String?                  @map("assigned_by_id") @db.Uuid
  assignedByName     String?                  @map("assigned_by_name")
  createdById        String?                  @map("created_by_id") @db.Uuid
  cancelledById      String?                  @map("cancelled_by_id") @db.Uuid
  cancelledAt        DateTime?                @map("cancelled_at")
  cancellationReason String?                  @map("cancellation_reason")
  metadata           Json?
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  deletedAt          DateTime?                @map("deleted_at")

  school       School                    @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear AcademicYear              @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term         Term                      @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  subject      Subject?                  @relation(fields: [subjectId, schoolId], references: [id, schoolId], onDelete: Restrict)
  assignedBy   User?                     @relation("ReinforcementTaskAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdBy    User?                     @relation("ReinforcementTaskCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  cancelledBy  User?                     @relation("ReinforcementTaskCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  targets      ReinforcementTaskTarget[]
  assignments  ReinforcementAssignment[]
  stages       ReinforcementTaskStage[]
  submissions  ReinforcementSubmission[]
  reviews      ReinforcementReview[]

  @@unique([id, schoolId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([subjectId])
  @@index([assignedById])
  @@index([createdById])
  @@index([cancelledById])
  @@index([schoolId, termId, status])
  @@index([schoolId, dueDate])
  @@index([schoolId, source])
  @@index([deletedAt])
  @@map("reinforcement_tasks")
}

