model AttendancePolicy {
  id                        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId                  String                   @map("school_id") @db.Uuid
  academicYearId            String                   @map("academic_year_id") @db.Uuid
  termId                    String                   @map("term_id") @db.Uuid
  scopeType                 AttendanceScopeType      @map("scope_type")
  scopeKey                  String                   @map("scope_key")
  stageId                   String?                  @map("stage_id") @db.Uuid
  gradeId                   String?                  @map("grade_id") @db.Uuid
  sectionId                 String?                  @map("section_id") @db.Uuid
  classroomId               String?                  @map("classroom_id") @db.Uuid
  nameAr                    String                   @map("name_ar")
  nameEn                    String                   @map("name_en")
  descriptionAr             String?                  @map("description_ar")
  descriptionEn             String?                  @map("description_en")
  notes                     String?
  mode                      AttendanceMode
  dailyComputationStrategy  DailyComputationStrategy @default(MANUAL) @map("daily_computation_strategy")
  requireExcuseAttachment   Boolean                  @default(false) @map("require_excuse_attachment")
  allowParentExcuseRequests Boolean                  @default(true) @map("allow_parent_excuse_requests")
  notifyGuardiansOnAbsence  Boolean                  @default(true) @map("notify_guardians_on_absence")
  effectiveFrom             DateTime?                @map("effective_from") @db.Date
  effectiveTo               DateTime?                @map("effective_to") @db.Date
  isActive                  Boolean                  @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school       School              @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  academicYear AcademicYear        @relation(fields: [academicYearId, schoolId], references: [id, schoolId], onDelete: Restrict)
  term         Term                @relation(fields: [termId, schoolId], references: [id, schoolId], onDelete: Restrict)
  stage        Stage?              @relation(fields: [stageId, schoolId], references: [id, schoolId], onDelete: Restrict)
  grade        Grade?              @relation(fields: [gradeId, schoolId], references: [id, schoolId], onDelete: Restrict)
  section      Section?            @relation(fields: [sectionId, schoolId], references: [id, schoolId], onDelete: Restrict)
  classroom    Classroom?          @relation(fields: [classroomId, schoolId], references: [id, schoolId], onDelete: Restrict)
  sessions     AttendanceSession[]

  @@unique([id, schoolId])
  @@unique([schoolId, academicYearId, termId, scopeType, scopeKey, nameAr], map: "attendance_policies_scope_name_ar_key")
  @@unique([schoolId, academicYearId, termId, scopeType, scopeKey, nameEn], map: "attendance_policies_scope_name_en_key")
  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([stageId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([classroomId])
  @@index([schoolId, academicYearId, termId])
  @@index([schoolId, termId, scopeType, scopeKey])
  @@index([schoolId, isActive, deletedAt])
  @@index([deletedAt])
  @@map("attendance_policies")
}

model AttendanceSession {
